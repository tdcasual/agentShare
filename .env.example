# API
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/agent_share
REDIS_URL=redis://redis:6379/0
SECRET_BACKEND=openbao
OPENBAO_ADDR=http://openbao:8200
OPENBAO_TOKEN=root
OPENBAO_MOUNT=secret
OPENBAO_PREFIX=agent-share
BOOTSTRAP_OWNER_KEY=changeme-bootstrap-key
MANAGEMENT_SESSION_SECRET=changeme-management-session-secret
MANAGEMENT_SESSION_SECURE=false

# Compose ports
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=8000
WEB_PORT=3000

# Web
AGENT_CONTROL_PLANE_API_URL=http://api:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
AGENT_CONTROL_PLANE_DEMO_MODE=false

# Optional image overrides
API_IMAGE=agentshare-api:local
WEB_IMAGE=agentshare-web:local
