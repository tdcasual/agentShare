# =============================================================================
# Local Development — docker compose up
# =============================================================================
# Usage: cp .env.example .env && docker compose up -d --build
# All values below are safe for local development. Change before deploying.
# =============================================================================

# ---- Secret Backend (OpenBao) ----
# Dev mode uses in-memory OpenBao with root token.
# API accepts these alternative names (via AliasChoices):
#   OPENBAO_ADDR  = SECRET_BACKEND_URL  (same field)
#   OPENBAO_TOKEN = SECRET_BACKEND_TOKEN (same field)
#   OPENBAO_TOKEN_FILE — reads token from file instead (used in Coolify)
SECRET_BACKEND=openbao
OPENBAO_ADDR=http://openbao:8200
OPENBAO_TOKEN=root
OPENBAO_MOUNT=secret
OPENBAO_PREFIX=agent-share

# ---- Data Stores ----
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/agent_share
REDIS_URL=redis://redis:6379/0
POSTGRES_PORT=5432
REDIS_PORT=6379

# ---- Application Secrets ----
# MUST change before any non-local deployment
BOOTSTRAP_OWNER_KEY=changeme-bootstrap-key
MANAGEMENT_SESSION_SECRET=changeme-management-session-secret
MANAGEMENT_SESSION_SECURE=false

# ---- Web (Next.js) ----
AGENT_CONTROL_PLANE_API_URL=http://api:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
AGENT_CONTROL_PLANE_DEMO_MODE=false
API_PORT=8000
WEB_PORT=3000

# ---- Optional LLM Runtime ----
# Uncomment and fill to enable AI agent integrations
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# GOOGLE_API_KEY=
