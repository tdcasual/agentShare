# API
DATABASE_URL=postgresql://postgres:change-me@postgres:5432/agent_share
REDIS_URL=redis://redis:6379/0
SECRET_BACKEND=openbao
OPENBAO_ADDR=http://openbao:8200
OPENBAO_TOKEN=change-me
OPENBAO_MOUNT=secret
OPENBAO_PREFIX=agent-share
BOOTSTRAP_AGENT_KEY=replace-with-long-random-value
MANAGEMENT_SESSION_SECRET=replace-with-long-random-value
MANAGEMENT_SESSION_SECURE=true

# Ports
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=8000
WEB_PORT=3000

# Web
AGENT_CONTROL_PLANE_API_URL=http://api:8000
NEXT_PUBLIC_API_BASE_URL=https://agentshare.example.com
AGENT_CONTROL_PLANE_DEMO_MODE=false

# Published images
API_IMAGE=ghcr.io/example/agentshare-api:latest
WEB_IMAGE=ghcr.io/example/agentshare-web:latest
