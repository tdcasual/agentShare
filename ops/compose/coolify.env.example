# =============================================================================
# Coolify / Self-hosted — docker compose -f docker-compose.coolify.yml up
# =============================================================================
# ALL values with "replace-with-*" MUST be changed before deployment.
# This stack includes a persistent OpenBao service with auto-bootstrap.
# =============================================================================

# ---- Public Routing ----
APP_ENV=production
PUBLIC_HOST=agentshare.example.com
APP_BASE_URL=https://agentshare.example.com
NEXT_PUBLIC_API_BASE_URL=https://agentshare.example.com
AGENT_CONTROL_PLANE_API_URL=http://api:8000
AGENT_CONTROL_PLANE_DEMO_MODE=false

# ---- Published Ports ----
API_PORT=8000
WEB_PORT=3000

# ---- Data Stores ----
POSTGRES_DB=agent_share
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
# Optional: leave DATABASE_URL unset for the default same-stack Postgres wiring.
# The compose file will derive it from POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB.
# Only set DATABASE_URL explicitly when pointing the API at a different database host.
REDIS_URL=redis://redis:6379/0

# ---- Secret Backend — Same-stack OpenBao ----
# Token is read from file after bootstrap (/openbao/bootstrap/root-token).
# The API also accepts OPENBAO_TOKEN directly as an alternative to TOKEN_FILE.
SECRET_BACKEND=openbao
OPENBAO_ADDR=http://openbao:8200
OPENBAO_TOKEN_FILE=/openbao/bootstrap/root-token
OPENBAO_MOUNT=secret
OPENBAO_PREFIX=agent-share

# ---- Application Secrets (REQUIRED) ----
BOOTSTRAP_OWNER_KEY=replace-with-long-random-value
MANAGEMENT_SESSION_SECRET=replace-with-long-random-value
MANAGEMENT_SESSION_COOKIE_NAME=management_session
MANAGEMENT_SESSION_SECURE=true

# ---- Optional LLM Runtime ----
# Uncomment and fill to enable AI agent integrations
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# GOOGLE_API_KEY=

# ---- Startup Behavior ----
RUN_DB_MIGRATIONS_ON_STARTUP=true
