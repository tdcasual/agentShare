# =============================================================================
# Production — docker compose -f docker-compose.prod.yml up
# =============================================================================
# ALL values with "replace-with-*" MUST be changed before deployment.
# This stack uses an EXTERNAL OpenBao/Vault instance (not in the compose).
# =============================================================================

# ---- Public Routing ----
APP_ENV=production
PUBLIC_HOST=agentshare.example.com
APP_BASE_URL=https://agentshare.example.com
ACME_EMAIL=ops@example.com
NEXT_PUBLIC_API_BASE_URL=https://agentshare.example.com
AGENT_CONTROL_PLANE_API_URL=http://api:8000
AGENT_CONTROL_PLANE_DEMO_MODE=false

# ---- Data Stores (REQUIRED) ----
POSTGRES_DB=agent_share
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql://postgres:replace-with-strong-password@postgres:5432/agent_share
REDIS_URL=redis://redis:6379/0

# ---- Secret Backend — External OpenBao/Vault (REQUIRED) ----
# The API accepts both naming conventions:
#   SECRET_BACKEND_URL  → mapped to OPENBAO_ADDR internally
#   SECRET_BACKEND_TOKEN → mapped to OPENBAO_TOKEN internally
# You can also use OPENBAO_ADDR/OPENBAO_TOKEN directly.
SECRET_BACKEND=openbao
SECRET_BACKEND_URL=https://vault.example.com
SECRET_BACKEND_TOKEN=replace-with-scoped-token
OPENBAO_MOUNT=secret
OPENBAO_PREFIX=agent-share

# ---- Application Secrets (REQUIRED) ----
BOOTSTRAP_OWNER_KEY=replace-with-long-random-value
MANAGEMENT_SESSION_SECRET=replace-with-long-random-value
MANAGEMENT_SESSION_COOKIE_NAME=management_session
MANAGEMENT_SESSION_SECURE=true

# ---- Container Images (REQUIRED) ----
API_IMAGE=ghcr.io/example/agentshare-api:latest
WEB_IMAGE=ghcr.io/example/agentshare-web:latest
